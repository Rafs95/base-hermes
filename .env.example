# ==============================================================================
# Hermes Custom Base Installer - Environment Variables Template
# ==============================================================================
# Copy this file to .env before starting the container:
#   cp installer/.env.example .env
# ==============================================================================

# Docker run settings
# Run `id -u` and `id -g` on your host terminal to get these values.
# Remaps the container user/group to prevent permissions issues in your mounted data volume.
HERMES_UID=1000
HERMES_GID=1000

# OpenAI-compatible API Server Key (mandatory for gateway api access)
API_SERVER_KEY=your-secret-api-server-key-here

# LLM Providers (Optionally pre-set keys if you bypass interactive setup)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# GitHub credentials for PR/issue integrations
GITHUB_TOKEN=
GH_TOKEN=
